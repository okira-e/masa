package main

Vector :: struct {
	x: usize,
	y: usize,
}

new_vector :: proc(x: usize, y: usize): Vector {
	return Vector {
		x: x,
		y: y,
	}
}

dimensions :: proc(foo: Vector): usize, usize {
	return foo.x, foo.y
}

v := Vector{x: 3, y: 5}
v = new_vector(3, 5)

x, y := dimensions(v)

foo :: proc(): usize {
	internal := 5
	
	return internal
}

main :: proc() {
	message: str = f"Hello {foo()} times!"
	
	println(message)
}
